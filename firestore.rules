rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: name (string), email (string), avatarColor (string), units (string)
    //
    // Collection: challenges
    // Fields: routeId (string), routeName (string), totalDistanceKm (number), mode (string),
    //         creatorId (string), partnerId (string), inviteCode (string), startDate (string),
    //         targetEndDate (string), status (string), nudgePartner (bool)
    //
    // Collection: logs
    // Fields: userId (string), challengeId (string), activityType (string), distanceKm (number),
    //         date (string), notes (string), createdAt (string)
    //
    // Collection: milestones
    // Fields: challengeId (string), userId (string), percentage (int), waypointIndex (int), unlockedAt (string)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gksplab2@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.name is string && 
             data.email is string && 
             data.avatarColor is string &&
             (!('units' in data) || data.units is string);
    }

    function isValidChallenge(data) {
      return data.keys().hasAll(['routeId', 'routeName', 'totalDistanceKm', 'mode', 'creatorId', 'startDate', 'status']) &&
             data.mode in ['solo', 'partner'] &&
             data.status in ['active', 'completed'] &&
             data.totalDistanceKm is number && data.totalDistanceKm > 0 &&
             (!('totalDistanceLogged' in data) || data.totalDistanceLogged is number) &&
             (!('nudgePartner' in data) || data.nudgePartner is bool);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'challengeId', 'activityType', 'distanceKm', 'date', 'createdAt']) &&
             data.activityType in ['walk', 'run', 'cycle', 'swim', 'other'] &&
             data.distanceKm is number && data.distanceKm > 0;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.creatorId ||
        request.auth.uid == resource.data.partnerId ||
        (request.method == 'get' && resource.data.mode == 'partner' && resource.data.partnerId == null)
      );
      allow create: if isAuthenticated() && isValidChallenge(request.resource.data);
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.creatorId ||
        request.auth.uid == resource.data.partnerId ||
        (resource.data.mode == 'partner' && resource.data.partnerId == null)
      ) && isValidChallenge(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.creatorId;
    }

    match /logs/{logId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        (exists(/databases/$(database)/documents/challenges/$(resource.data.challengeId)) && (
          get(/databases/$(database)/documents/challenges/$(resource.data.challengeId)).data.creatorId == request.auth.uid ||
          get(/databases/$(database)/documents/challenges/$(resource.data.challengeId)).data.partnerId == request.auth.uid
        ))
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidLog(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /milestones/{milestoneId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        (exists(/databases/$(database)/documents/challenges/$(resource.data.challengeId)) && (
          get(/databases/$(database)/documents/challenges/$(resource.data.challengeId)).data.creatorId == request.auth.uid ||
          get(/databases/$(database)/documents/challenges/$(resource.data.challengeId)).data.partnerId == request.auth.uid
        ))
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
  }
}
